---
import { sitio } from '../config';

// Año dinámico (no "2026" literal) — se calcula en el build.
const anio = new Date().getFullYear();

// Placeholders por ahora; los reales se cablean en la Tanda 1.
const redes = [
  { nombre: 'Instagram', href: sitio.redes?.instagram ?? '#' },
  { nombre: 'Behance', href: sitio.redes?.behance ?? '#' },
  {
    nombre: 'Email',
    href: sitio.redes?.email ? `mailto:${sitio.redes.email}` : '#',
  },
];
---

<footer class="bg-tinta text-crema mt-20">
  <div class="max-w-6xl mx-auto px-6 py-16 text-center">
    <p class="font-display text-3xl text-hueso">{sitio.nombre}</p>
    <p class="mt-2 text-crema">{sitio.tagline}</p>

    <div class="mt-8 flex justify-center gap-6">
      {redes.map((r) => (
        <a href={r.href} class="text-crema transition hover:text-coral">{r.nombre}</a>
      ))}
    </div>

    <p class="mt-10 border-t border-tinta-suave pt-8 text-sm text-crema">
      © {anio} {sitio.nombre}. Todos los derechos reservados.
    </p>
    <p class="mt-2 text-xs text-crema">
      Sitio por <a href="https://mi-portafolio-eta-hazel.vercel.app/" target="_blank" rel="noopener" class="text-coral hover:underline">Kervin Martínez</a>
    </p>
  </div>
</footer>
