---
import { sitio } from '../config';
---

<footer id="contacto" class="bg-gray-900 text-gray-300 py-12 px-6 mt-10">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-2xl font-bold text-white mb-2">{sitio.nombre}</h2>
    <p class="text-gray-400 mb-6">{sitio.tagline}</p>

    <div class="flex justify-center gap-6 mb-8">
      <a href={sitio.redes.instagram} class="hover:text-indigo-400 transition">Instagram</a>
      <a href={sitio.redes.behance} class="hover:text-indigo-400 transition">Behance</a>
      <a href={`mailto:${sitio.redes.email}`} class="hover:text-indigo-400 transition">Email</a>
    </div>

    <p class="text-gray-500 text-sm border-t border-gray-800 pt-6">
      © 2026 {sitio.nombre}. Todos los derechos reservados.
    </p>
  </div>
</footer>