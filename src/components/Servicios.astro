---
import { sitio, servicios } from '../config';
import Seccion from './Seccion.astro';
import TituloSeccion from './TituloSeccion.astro';
import TarjetaServicio from './TarjetaServicio.astro';
---

<Seccion id="servicios">
  <TituloSeccion titulo={sitio.serviciosTitulo} centrado class="mb-10 sm:mb-14" />

  <!-- 1 col móvil · 2x2 tablet · 4 col desktop -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-4">
    {servicios.map((s, i) => <TarjetaServicio servicio={s} indice={i} />)}
  </div>
</Seccion>
