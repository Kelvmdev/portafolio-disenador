---
import { sitio } from '../config';
import { imagenOptimizada } from '../lib/img';
import Seccion from './Seccion.astro';
import TituloSeccion from './TituloSeccion.astro';
import PlaceholderMarca from './PlaceholderMarca.astro';

const sobre = sitio.sobre;
const tieneFoto = Boolean(sobre.foto) && sobre.foto.startsWith('http');

// Acota el tamaño del media: max-w + max-h para que la sección no crezca de más.
const media = 'aspect-[4/5] w-full max-w-[400px] max-h-[500px] mx-auto rounded-2xl';
---

<Seccion id="sobre">
  <div class="grid items-center gap-10 md:grid-cols-2 lg:gap-16">
    <!-- Foto / placeholder de marca (TEMPORAL — se reemplaza por la URL real) -->
    <div>
      {tieneFoto ? (
        <img
          src={imagenOptimizada(sobre.foto, 800)}
          alt={`Foto de ${sitio.nombre}`}
          loading="lazy"
          decoding="async"
          class={`${media} object-cover`}
        />
      ) : (
        <PlaceholderMarca texto={sitio.nombre} class={media} />
      )}
    </div>

    <!-- Texto -->
    <div>
      <TituloSeccion titulo={sitio.sobreTitulo} />
      <p class="mt-5 text-lg leading-relaxed text-tinta-suave">{sobre.bio}</p>
    </div>
  </div>
</Seccion>
