---
import type { Servicio } from '../config';

interface Props {
  servicio: Servicio;
  indice?: number;
}
const { servicio, indice = 0 } = Astro.props;

// Iconos inline simples (decorativos, aria-hidden). currentColor = coral-deep del chip.
const iconos = [
  // Instagram
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.6"/><circle cx="17.4" cy="6.6" r="1" fill="currentColor" stroke="none"/></svg>`,
  // Identidad de marca (sparkle)
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="M12 3l1.9 6.1L20 11l-6.1 1.9L12 19l-1.9-6.1L4 11l6.1-1.9z"/></svg>`,
  // Reels y motion (play)
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><path d="M10 8.5l5.5 3.5L10 15.5z" fill="currentColor" stroke="none"/></svg>`,
  // Campañas y flyers (megáfono)
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10v4h3l6 4V6L6 10H3z"/><path d="M16.5 9a4 4 0 0 1 0 6"/></svg>`,
];
const icono = iconos[indice % iconos.length];
---

<div class="h-full rounded-2xl border border-linea bg-crema p-6 motion-safe:transition hover:shadow-md">
  <span
    class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-hueso text-coral-deep"
    aria-hidden="true"
    set:html={icono}
  ></span>
  <h3 class="mt-4 font-display text-xl text-tinta">{servicio.titulo}</h3>
  <p class="mt-2 text-sm leading-relaxed text-tinta-suave">{servicio.descripcion}</p>
</div>
