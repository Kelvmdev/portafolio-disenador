---
import { sitio, piezas } from '../config';
import Seccion from './Seccion.astro';
import TituloSeccion from './TituloSeccion.astro';
import PiezaTrabajo from './PiezaTrabajo.astro';
---

<Seccion id="trabajos">
  <TituloSeccion titulo={sitio.trabajosTitulo} centrado class="mb-10 sm:mb-14" />

  <!-- Bento asimétrico: el destacado ocupa 2x2; degrada a 2 col (tablet) y 1 col (móvil). -->
  <div class="grid grid-cols-1 gap-4 sm:gap-5 md:grid-cols-2 md:auto-rows-[14rem] lg:grid-cols-3 lg:auto-rows-[15rem]">
    {piezas.map((p) => (
      <PiezaTrabajo pieza={p} clase={p.destacado ? 'md:col-span-2 md:row-span-2' : ''} />
    ))}
  </div>
</Seccion>
