---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { sitio } from '../config';

const { titulo = sitio.seo.title, descripcion = sitio.seo.description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const imagenOG = new URL('/og.png', Astro.site).href;
const ogAlt = `${sitio.nombre} — ${sitio.tagline}`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#c5371a" />
    <meta name="generator" content={Astro.generator} />

    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (WhatsApp, Facebook, Instagram) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={sitio.nombre} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imagenOG} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={imagenOG} />

    <slot name="head" />
  </head>
  <body>
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded-lg focus:bg-coral-deep focus:px-4 focus:py-2 focus:text-hueso"
    >
      Saltar al contenido
    </a>
    <Navbar />
    <main id="contenido" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
