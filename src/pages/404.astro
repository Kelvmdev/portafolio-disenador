---
import Layout from '../layouts/Layout.astro';
import Boton from '../components/Boton.astro';
import { sitio } from '../config';
---

<Layout titulo={`Página no encontrada — ${sitio.nombre}`}>
  <meta name="robots" content="noindex" slot="head" />
  <section class="max-w-2xl mx-auto px-6 py-28 sm:py-36 text-center">
    <p class="font-display text-7xl sm:text-8xl text-coral-deep">404</p>
    <h1 class="mt-4 font-display text-3xl sm:text-4xl text-tinta">Esta página no existe</h1>
    <p class="mt-4 text-lg text-tinta-suave">
      Puede que el enlace esté roto o la página se haya movido.
    </p>
    <div class="mt-8 flex justify-center">
      <Boton href="/">Volver al inicio</Boton>
    </div>
  </section>
</Layout>
