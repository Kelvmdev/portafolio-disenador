---
export const prerender = false;
import '../../styles/global.css';
import datos from '../../data.json';

const sesion = Astro.cookies.get('sesion')?.value;
const autenticado = sesion === 'ok';
const error = Astro.url.searchParams.has('error');
const guardado = Astro.url.searchParams.has('guardado');
const errorGuardar = Astro.url.searchParams.has('error_guardar');

const s = datos.sitio;
const inp = 'w-full rounded-lg border border-linea bg-hueso px-3 py-2 text-tinta';
const lbl = 'block text-sm font-medium text-tinta mb-1';
const card = 'rounded-2xl border border-linea bg-crema p-5 space-y-4';
const leyenda = 'font-display text-lg text-tinta';

// Para inyectar el estado inicial sin riesgo de cerrar el <script>.
const estadoInicial = JSON.stringify(datos).replace(/</g, '\\u003c');
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel · {s.nombre}</title>
  </head>
  <body class="min-h-screen p-4 sm:p-6">
    {autenticado ? (
      <div class="max-w-3xl mx-auto">
        <header class="flex items-center justify-between mb-1">
          <h1 class="font-display text-3xl text-tinta">Panel de contenido</h1>
          <a href="/api/logout" class="text-sm text-tinta-suave underline hover:text-coral-deep">Cerrar sesión</a>
        </header>
        <p class="text-tinta-suave text-sm mb-6">Edita todo el sitio y pulsa “Guardar todo”.</p>

        {guardado && <p class="mb-6 rounded-lg bg-crema border border-linea px-3 py-2 text-sm text-tinta">✅ Guardado. Vercel redesplegará en ~30 s (recarga con Ctrl+Shift+R).</p>}
        {errorGuardar && <p class="mb-6 rounded-lg border border-error px-3 py-2 text-sm text-error">⚠️ No se pudo guardar. Revisa tu conexión e intenta de nuevo.</p>}

        <form method="POST" action="/api/guardar">
          <input type="hidden" name="payload" id="payload" />

          <!-- Pestañas -->
          <div role="tablist" aria-label="Secciones" class="flex flex-wrap gap-2 mb-5">
            <button type="button" role="tab" data-tab="sitio" aria-selected="true" class="rounded-full px-4 py-2 text-sm font-medium aria-selected:bg-tinta aria-selected:text-hueso border border-linea text-tinta">Sitio</button>
            <button type="button" role="tab" data-tab="trabajos" aria-selected="false" class="rounded-full px-4 py-2 text-sm font-medium aria-selected:bg-tinta aria-selected:text-hueso border border-linea text-tinta">Trabajos</button>
            <button type="button" role="tab" data-tab="servicios" aria-selected="false" class="rounded-full px-4 py-2 text-sm font-medium aria-selected:bg-tinta aria-selected:text-hueso border border-linea text-tinta">Servicios</button>
          </div>

          <!-- ===== PESTAÑA SITIO ===== -->
          <div role="tabpanel" data-panel="sitio" class="space-y-5">
            <fieldset class={card}>
              <legend class={leyenda}>Identidad</legend>
              <div>
                <label for="f-nombre" class={lbl}>Nombre</label>
                <input id="f-nombre" data-path="sitio.nombre" value={s.nombre} autocomplete="off" class={inp} />
              </div>
              <div>
                <label for="f-kicker" class={lbl}>Kicker (sobre el titular)</label>
                <input id="f-kicker" data-path="sitio.kicker" value={s.kicker} autocomplete="off" class={inp} />
              </div>
              <div>
                <label for="f-rol" class={lbl}>Rol (para el SEO / JSON-LD)</label>
                <input id="f-rol" data-path="sitio.rol" value={s.rol} autocomplete="off" class={inp} />
              </div>
            </fieldset>

            <fieldset class={card}>
              <legend class={leyenda}>SEO (título y descripción de Google/redes)</legend>
              <div>
                <label for="f-seo-title" class={lbl}>Título (~50-60 caracteres)</label>
                <input id="f-seo-title" data-path="sitio.seo.title" value={s.seo.title} autocomplete="off" class={inp} />
              </div>
              <div>
                <label for="f-seo-desc" class={lbl}>Descripción (~120-160 caracteres)</label>
                <textarea id="f-seo-desc" data-path="sitio.seo.description" rows="3" autocomplete="off" class={inp}>{s.seo.description}</textarea>
              </div>
            </fieldset>

            <fieldset class={card}>
              <legend class={leyenda}>Hero</legend>
              <div class="grid sm:grid-cols-3 gap-3">
                <div>
                  <label for="f-tit-antes" class={lbl}>Titular · antes</label>
                  <input id="f-tit-antes" data-path="sitio.titular.antes" value={s.titular.antes} autocomplete="off" class={inp} />
                </div>
                <div>
                  <label for="f-tit-dest" class={lbl}>Titular · destacado</label>
                  <input id="f-tit-dest" data-path="sitio.titular.destacado" value={s.titular.destacado} autocomplete="off" class={inp} />
                </div>
                <div>
                  <label for="f-tit-desp" class={lbl}>Titular · después</label>
                  <input id="f-tit-desp" data-path="sitio.titular.despues" value={s.titular.despues} autocomplete="off" class={inp} />
                </div>
              </div>
              <div>
                <label for="f-subtitulo" class={lbl}>Subtítulo</label>
                <input id="f-subtitulo" data-path="sitio.subtitulo" value={s.subtitulo} autocomplete="off" class={inp} />
              </div>

              <p class="text-sm font-medium text-tinta">Métricas</p>
              <div class="space-y-2">
                {s.metricas.map((m, i) => (
                  <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 rounded-lg border border-linea p-2">
                    <label class="text-xs text-tinta-suave">Número
                      <input type="number" step="any" data-path={`sitio.metricas.${i}.numero`} data-tipo="number" value={m.numero} autocomplete="off" class={inp} />
                    </label>
                    <label class="text-xs text-tinta-suave">Prefijo
                      <input data-path={`sitio.metricas.${i}.prefijo`} value={m.prefijo} autocomplete="off" class={inp} />
                    </label>
                    <label class="text-xs text-tinta-suave">Sufijo
                      <input data-path={`sitio.metricas.${i}.sufijo`} value={m.sufijo} autocomplete="off" class={inp} />
                    </label>
                    <label class="text-xs text-tinta-suave">Decimales
                      <input type="number" step="1" min="0" data-path={`sitio.metricas.${i}.decimales`} data-tipo="number" value={m.decimales} autocomplete="off" class={inp} />
                    </label>
                    <label class="text-xs text-tinta-suave col-span-2 sm:col-span-1">Etiqueta
                      <input data-path={`sitio.metricas.${i}.etiqueta`} value={m.etiqueta} autocomplete="off" class={inp} />
                    </label>
                  </div>
                ))}
              </div>
            </fieldset>

            <fieldset class={card}>
              <legend class={leyenda}>Títulos de sección</legend>
              <div class="grid sm:grid-cols-3 gap-3">
                <div>
                  <label for="f-tt" class={lbl}>Trabajos</label>
                  <input id="f-tt" data-path="sitio.trabajosTitulo" value={s.trabajosTitulo} autocomplete="off" class={inp} />
                </div>
                <div>
                  <label for="f-st" class={lbl}>Sobre mí</label>
                  <input id="f-st" data-path="sitio.sobreTitulo" value={s.sobreTitulo} autocomplete="off" class={inp} />
                </div>
                <div>
                  <label for="f-svt" class={lbl}>Servicios</label>
                  <input id="f-svt" data-path="sitio.serviciosTitulo" value={s.serviciosTitulo} autocomplete="off" class={inp} />
                </div>
              </div>
            </fieldset>

            <fieldset class={card}>
              <legend class={leyenda}>Sobre mí</legend>
              <div>
                <label for="f-bio" class={lbl}>Bio</label>
                <textarea id="f-bio" data-path="sitio.sobre.bio" rows="5" autocomplete="off" class={inp}>{s.sobre.bio}</textarea>
              </div>
              <div>
                <label for="f-foto" class={lbl}>Foto</label>
                <div class="flex items-center gap-3">
                  <img data-sobre-preview src={s.sobre.foto} alt="Foto de Sobre mí" class={`h-16 w-16 rounded-lg border border-linea object-cover ${s.sobre.foto ? '' : 'hidden'}`} />
                  <input id="f-foto" type="file" accept="image/*" data-upload="sobre-foto" autocomplete="off" class="text-sm text-tinta-suave" />
                </div>
                <p data-sobre-status class="text-xs text-tinta-suave min-h-4"></p>
              </div>
            </fieldset>

            <fieldset class={card}>
              <legend class={leyenda}>Contacto</legend>
              <div>
                <label for="f-ct" class={lbl}>Título</label>
                <input id="f-ct" data-path="sitio.contacto.titulo" value={s.contacto.titulo} autocomplete="off" class={inp} />
              </div>
              <div>
                <label for="f-cx" class={lbl}>Texto</label>
                <textarea id="f-cx" data-path="sitio.contacto.texto" rows="3" autocomplete="off" class={inp}>{s.contacto.texto}</textarea>
              </div>
              <div>
                <label for="f-fs" class={lbl}>Endpoint de Formspree</label>
                <input id="f-fs" data-path="sitio.formspree" value={s.formspree} autocomplete="off" class={inp} />
              </div>
            </fieldset>

            <fieldset class={card}>
              <legend class={leyenda}>Redes</legend>
              <div>
                <label for="f-ig" class={lbl}>Instagram (URL)</label>
                <input id="f-ig" type="url" data-path="sitio.redes.instagram" value={s.redes.instagram} autocomplete="off" class={inp} />
              </div>
              <div>
                <label for="f-be" class={lbl}>Behance (URL)</label>
                <input id="f-be" type="url" data-path="sitio.redes.behance" value={s.redes.behance} autocomplete="off" class={inp} />
              </div>
              <div>
                <label for="f-em" class={lbl}>Email</label>
                <input id="f-em" type="email" data-path="sitio.redes.email" value={s.redes.email} autocomplete="off" class={inp} />
              </div>
            </fieldset>
          </div>

          <!-- ===== PESTAÑA TRABAJOS ===== -->
          <div role="tabpanel" data-panel="trabajos" hidden class="space-y-4">
            <div id="lista-trabajos" class="space-y-4"></div>
            <button type="button" id="add-trabajo" class="w-full rounded-lg border-2 border-dashed border-linea py-2.5 text-sm font-medium text-coral-deep hover:bg-crema motion-safe:transition active:scale-95">
              ➕ Agregar trabajo
            </button>
          </div>

          <!-- ===== PESTAÑA SERVICIOS ===== -->
          <div role="tabpanel" data-panel="servicios" hidden class="space-y-4">
            <div id="lista-servicios" class="space-y-4"></div>
            <button type="button" id="add-servicio" class="w-full rounded-lg border-2 border-dashed border-linea py-2.5 text-sm font-medium text-coral-deep hover:bg-crema motion-safe:transition active:scale-95">
              ➕ Agregar servicio
            </button>
          </div>

          <!-- Guardar -->
          <div class="sticky bottom-0 mt-6 -mx-4 sm:mx-0 bg-hueso/95 px-4 py-4 sm:px-0">
            <button type="submit" class="w-full rounded-full bg-coral-deep px-6 py-3 font-medium text-hueso motion-safe:transition motion-safe:duration-150 active:scale-95 hover:shadow-lg">
              Guardar todo
            </button>
          </div>
        </form>
      </div>
    ) : (
      <div class="flex justify-center pt-16">
        <form method="POST" action="/api/login" autocomplete="on" class="w-full max-w-sm rounded-2xl border border-linea bg-crema p-8">
          <h1 class="font-display text-3xl text-tinta mb-1">Panel</h1>
          <p class="text-tinta-suave text-sm mb-6">Ingresa tu clave para entrar.</p>
          {error && <p class="mb-4 rounded-lg border border-error px-3 py-2 text-sm text-error">Clave incorrecta. Intenta de nuevo.</p>}
          <label for="password" class={lbl}>Clave</label>
          <input id="password" name="password" type="password" required autocomplete="current-password" placeholder="Tu clave" class={`${inp} mb-4`} />
          <button type="submit" class="w-full rounded-full bg-coral-deep px-6 py-3 font-medium text-hueso motion-safe:transition motion-safe:duration-150 active:scale-95 hover:shadow-lg">
            Entrar
          </button>
        </form>
      </div>
    )}

    {autenticado && (
      <script type="application/json" id="estado-inicial" set:html={estadoInicial}></script>
      <script>
        const estadoEl = document.getElementById('estado-inicial');
        if (estadoEl) {
        const CLOUD_NAME = 'dw26ujhoo';
        const UPLOAD_PRESET = 'portafolio_unsigned';

        const estado = JSON.parse(estadoEl.textContent || '{}');
        const esc = (v: unknown) =>
          String(v ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

        // ---- helpers de path (Sitio) ----
        function setPath(obj: any, path: string, value: unknown) {
          const parts = path.split('.');
          let o = obj;
          for (let i = 0; i < parts.length - 1; i++) o = o[parts[i]];
          o[parts[parts.length - 1]] = value;
        }

        document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[data-path]').forEach((el) => {
          el.addEventListener('input', () => {
            const v = el.dataset.tipo === 'number' ? (el.value === '' ? 0 : Number(el.value)) : el.value;
            setPath(estado, el.dataset.path!, v);
          });
        });

        // ---- Cloudinary ----
        async function subir(file: File): Promise<string> {
          const fd = new FormData();
          fd.append('file', file);
          fd.append('upload_preset', UPLOAD_PRESET);
          const r = await fetch(`https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`, { method: 'POST', body: fd });
          if (!r.ok) throw new Error('fallo');
          return (await r.json()).secure_url as string;
        }

        // ---- Sobre: foto ----
        const fileSobre = document.querySelector<HTMLInputElement>('[data-upload="sobre-foto"]');
        fileSobre?.addEventListener('change', async () => {
          const f = fileSobre.files?.[0];
          if (!f) return;
          const st = document.querySelector('[data-sobre-status]')!;
          const prev = document.querySelector<HTMLImageElement>('[data-sobre-preview]')!;
          st.textContent = '⏳ Subiendo…';
          try {
            const url = await subir(f);
            estado.sitio.sobre.foto = url;
            prev.src = url;
            prev.classList.remove('hidden');
            st.textContent = '✅ Imagen lista';
          } catch {
            st.textContent = '⚠️ No se pudo subir';
          }
          fileSobre.value = '';
        });

        // ---- TRABAJOS ----
        const listaTrab = document.getElementById('lista-trabajos')!;
        function filaTrabajo(t: any, i: number) {
          const galeria = (t.galeria ?? []).map((u: string, gi: number) => `
            <span class="relative inline-block">
              <img src="${esc(u)}" alt="Imagen ${gi + 1} de ${esc(t.titulo)}" class="h-14 w-14 rounded-lg border border-linea object-cover" />
              <button type="button" data-galeria-quitar data-i="${i}" data-gi="${gi}" aria-label="Quitar imagen ${gi + 1}" class="absolute -right-1 -top-1 rounded-full bg-coral-deep px-1.5 text-xs text-hueso">×</button>
            </span>`).join('');
          return `
          <div class="rounded-xl border border-linea bg-hueso p-4 space-y-3">
            <div class="flex items-center justify-between">
              <p class="text-xs font-semibold uppercase text-tinta-suave">Trabajo ${i + 1}</p>
              <div class="flex items-center gap-2">
                <button type="button" data-mover data-dir="-1" data-i="${i}" aria-label="Subir" class="text-tinta-suave hover:text-tinta">↑</button>
                <button type="button" data-mover data-dir="1" data-i="${i}" aria-label="Bajar" class="text-tinta-suave hover:text-tinta">↓</button>
                <button type="button" data-borrar-trab data-i="${i}" class="text-sm text-coral-deep hover:underline">Borrar</button>
              </div>
            </div>
            <label class="block text-sm text-tinta-suave">Título
              <input data-tc="titulo" data-i="${i}" value="${esc(t.titulo)}" autocomplete="off" class="w-full rounded-lg border border-linea bg-hueso px-3 py-2 text-tinta" />
            </label>
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="block text-sm text-tinta-suave">Categoría
                <input data-tc="categoria" data-i="${i}" value="${esc(t.categoria)}" autocomplete="off" class="w-full rounded-lg border border-linea bg-hueso px-3 py-2 text-tinta" />
              </label>
              <label class="block text-sm text-tinta-suave">Engagement
                <input data-tc="engagement" data-i="${i}" value="${esc(t.engagement)}" autocomplete="off" class="w-full rounded-lg border border-linea bg-hueso px-3 py-2 text-tinta" />
              </label>
            </div>
            <label class="flex items-center gap-2 text-sm text-tinta">
              <input type="checkbox" data-destacado data-i="${i}" ${t.destacado ? 'checked' : ''} /> Destacado (celda grande)
            </label>
            <div>
              <p class="text-sm text-tinta-suave mb-1">Portada</p>
              <div class="flex items-center gap-3">
                <img src="${esc(t.imagen)}" alt="Portada de ${esc(t.titulo)}" class="h-14 w-14 rounded-lg border border-linea object-cover ${t.imagen ? '' : 'hidden'}" data-portada-prev data-i="${i}" />
                <input type="file" accept="image/*" data-portada data-i="${i}" autocomplete="off" class="text-sm text-tinta-suave" />
              </div>
            </div>
            <div>
              <p class="text-sm text-tinta-suave mb-1">Galería</p>
              <div class="flex flex-wrap gap-2 mb-2">${galeria}</div>
              <input type="file" accept="image/*" multiple data-galeria-add data-i="${i}" autocomplete="off" class="text-sm text-tinta-suave" />
            </div>
            <p data-trab-status data-i="${i}" class="text-xs text-tinta-suave min-h-4"></p>
          </div>`;
        }
        function renderTrabajos() {
          listaTrab.innerHTML = estado.trabajos.map((t: any, i: number) => filaTrabajo(t, i)).join('');
        }

        listaTrab.addEventListener('input', (e) => {
          const el = e.target as HTMLInputElement;
          if (el.dataset.tc) estado.trabajos[Number(el.dataset.i)][el.dataset.tc] = el.value;
        });
        listaTrab.addEventListener('change', async (e) => {
          const el = e.target as HTMLInputElement;
          const i = Number(el.dataset.i);
          if (el.hasAttribute('data-destacado')) {
            estado.trabajos[i].destacado = el.checked;
            return;
          }
          if (el.dataset.portada !== undefined && el.matches('[data-portada]')) {
            const f = el.files?.[0]; if (!f) return;
            const st = listaTrab.querySelector(`[data-trab-status][data-i="${i}"]`)!;
            st.textContent = '⏳ Subiendo portada…';
            try { estado.trabajos[i].imagen = await subir(f); st.textContent = '✅ Portada lista'; renderTrabajos(); }
            catch { st.textContent = '⚠️ No se pudo subir'; }
            return;
          }
          if (el.matches('[data-galeria-add]')) {
            const files = Array.from(el.files ?? []);
            if (!files.length) return;
            const st = listaTrab.querySelector(`[data-trab-status][data-i="${i}"]`)!;
            let ok = 0;
            for (const f of files) {
              st.textContent = `⏳ Subiendo ${ok + 1} de ${files.length}…`;
              try { estado.trabajos[i].galeria.push(await subir(f)); ok++; } catch { /* sigue */ }
            }
            st.textContent = ok === files.length ? `✅ ${ok} agregada(s)` : `⚠️ ${ok} de ${files.length}`;
            renderTrabajos();
          }
        });
        listaTrab.addEventListener('click', (e) => {
          const el = (e.target as HTMLElement).closest('button');
          if (!el) return;
          const i = Number(el.dataset.i);
          if (el.hasAttribute('data-borrar-trab')) { estado.trabajos.splice(i, 1); renderTrabajos(); }
          else if (el.hasAttribute('data-mover')) {
            const j = i + Number(el.dataset.dir);
            if (j < 0 || j >= estado.trabajos.length) return;
            [estado.trabajos[i], estado.trabajos[j]] = [estado.trabajos[j], estado.trabajos[i]];
            renderTrabajos();
          } else if (el.hasAttribute('data-galeria-quitar')) {
            estado.trabajos[i].galeria.splice(Number(el.dataset.gi), 1); renderTrabajos();
          }
        });
        document.getElementById('add-trabajo')!.addEventListener('click', () => {
          estado.trabajos.push({ titulo: '', categoria: '', engagement: '', destacado: false, imagen: '', galeria: [], orden: estado.trabajos.length + 1 });
          renderTrabajos();
        });

        // ---- SERVICIOS ----
        const listaServ = document.getElementById('lista-servicios')!;
        function filaServicio(sv: any, i: number) {
          return `
          <div class="rounded-xl border border-linea bg-hueso p-4 space-y-3">
            <div class="flex items-center justify-between">
              <p class="text-xs font-semibold uppercase text-tinta-suave">Servicio ${i + 1}</p>
              <button type="button" data-borrar-serv data-i="${i}" class="text-sm text-coral-deep hover:underline">Borrar</button>
            </div>
            <label class="block text-sm text-tinta-suave">Título
              <input data-sc="titulo" data-i="${i}" value="${esc(sv.titulo)}" autocomplete="off" class="w-full rounded-lg border border-linea bg-hueso px-3 py-2 text-tinta" />
            </label>
            <label class="block text-sm text-tinta-suave">Descripción
              <input data-sc="descripcion" data-i="${i}" value="${esc(sv.descripcion)}" autocomplete="off" class="w-full rounded-lg border border-linea bg-hueso px-3 py-2 text-tinta" />
            </label>
          </div>`;
        }
        function renderServicios() {
          listaServ.innerHTML = estado.servicios.map((sv: any, i: number) => filaServicio(sv, i)).join('');
        }
        listaServ.addEventListener('input', (e) => {
          const el = e.target as HTMLInputElement;
          if (el.dataset.sc) estado.servicios[Number(el.dataset.i)][el.dataset.sc] = el.value;
        });
        listaServ.addEventListener('click', (e) => {
          const el = (e.target as HTMLElement).closest('button');
          if (el?.hasAttribute('data-borrar-serv')) { estado.servicios.splice(Number(el.dataset.i), 1); renderServicios(); }
        });
        document.getElementById('add-servicio')!.addEventListener('click', () => {
          estado.servicios.push({ titulo: '', descripcion: '' });
          renderServicios();
        });

        // ---- Pestañas ----
        const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
        const paneles = document.querySelectorAll<HTMLElement>('[data-panel]');
        tabs.forEach((t) => t.addEventListener('click', () => {
          tabs.forEach((x) => x.setAttribute('aria-selected', String(x === t)));
          paneles.forEach((p) => { p.hidden = p.dataset.panel !== t.dataset.tab; });
        }));

        // ---- Guardar: vuelca el estado al payload (orden recalculado) ----
        const form = document.querySelector('form[action="/api/guardar"]') as HTMLFormElement;
        form.addEventListener('submit', () => {
          estado.trabajos.forEach((t: any, i: number) => { t.orden = i + 1; });
          (document.getElementById('payload') as HTMLInputElement).value = JSON.stringify(estado);
        });

        renderTrabajos();
        renderServicios();
        }
      </script>
    )}
  </body>
</html>
