---
export const prerender = false;
import '../../styles/global.css';
import { sitio, trabajos } from '../../config';

const sesion = Astro.cookies.get("sesion")?.value;
const autenticado = sesion === "ok";
const error = Astro.url.searchParams.has("error");
const guardado = Astro.url.searchParams.has("guardado");
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel</title>
  </head>
  <body class="bg-gray-100 min-h-screen p-6">
    {autenticado ? (
      <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-lg p-8">
        <div class="flex items-center justify-between mb-1">
          <h1 class="text-2xl font-bold text-gray-900">Panel de contenido</h1>
          <a href="/api/logout" class="text-sm text-gray-500 hover:text-gray-700 underline">Cerrar sesión</a>
        </div>
        <p class="text-gray-500 text-sm mb-6">Edita la información de tu sitio.</p>
        {guardado && <p class="bg-green-50 text-green-700 text-sm rounded-lg px-3 py-2 mb-6">✅ Guardado con éxito.</p>}

        <form method="POST" action="/api/guardar" class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
            <input type="text" name="nombre" value={sitio.nombre}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tagline</label>
            <input type="text" name="tagline" value={sitio.tagline}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" />
          </div>

          <hr class="border-gray-200" />
          <h2 class="text-lg font-bold text-gray-900">Trabajos</h2>

          <div id="lista-trabajos" class="space-y-4">
            {trabajos.map((t, i) => (
              <div data-trabajo class="border border-gray-200 rounded-xl p-4 space-y-3">
                <div class="flex justify-between items-center">
                  <p data-label class="text-xs font-semibold text-gray-400 uppercase">Trabajo {i + 1}</p>
                  <button type="button" data-borrar class="text-red-600 text-sm hover:underline">🗑️ Borrar trabajo</button>
                </div>
                <input type="text" name={`nombre_${i}`} data-nombre value={t.nombre} placeholder="Nombre"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" />
                <input type="text" name={`titulo_${i}`} data-titulo value={t.titulo} placeholder="Título"
                  class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" />

                <p class="text-xs font-medium text-gray-500">Imágenes</p>
                <div data-imagenes class="space-y-2 max-h-64 overflow-y-auto pr-1">
                  {t.imagenes.map((url: string) => (
                    <div data-img class="flex items-center gap-3">
                      <img src={url} class="w-16 h-16 object-cover rounded-lg border border-gray-200" />
                      <button type="button" data-borrar-img class="text-red-600 text-xs hover:underline">Quitar</button>
                    </div>
                  ))}
                </div>

                <input type="file" accept="image/*" multiple data-file
                  class="w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-indigo-600 file:text-white file:cursor-pointer hover:file:bg-indigo-700" />
                <p data-upload-status class="text-xs text-gray-500 min-h-4"></p>

                <input type="hidden" name={`imagenes_${i}`} data-imagenes-json value={JSON.stringify(t.imagenes)} />
              </div>
            ))}
          </div>

          <button type="button" id="btn-agregar" class="w-full border-2 border-dashed border-indigo-300 text-indigo-600 font-medium py-2.5 rounded-lg hover:bg-indigo-50 transition">
            ➕ Agregar trabajo
          </button>

          <input type="hidden" name="total" id="total" value={trabajos.length} />

          <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-lg transition">
            Guardar
          </button>
        </form>
      </div>
    ) : (
      <div class="flex justify-center pt-16">
        <form method="POST" action="/api/login" class="bg-white rounded-2xl shadow-lg p-8 max-w-sm w-full">
          <h1 class="text-2xl font-bold text-gray-900 mb-1">Panel</h1>
          <p class="text-gray-500 text-sm mb-6">Ingresa tu clave para entrar.</p>
          {error && <p class="bg-red-50 text-red-600 text-sm rounded-lg px-3 py-2 mb-4">Clave incorrecta. Intenta de nuevo.</p>}
          <input type="password" name="password" placeholder="Tu clave" required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg mb-4 focus:outline-none focus:border-indigo-600" />
          <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-lg transition">
            Entrar
          </button>
        </form>
      </div>
    )}
    <script>
      const lista = document.getElementById('lista-trabajos') as HTMLElement;

      if (lista) {
        const totalInput = document.getElementById('total') as HTMLInputElement;
        const btnAgregar = document.getElementById('btn-agregar') as HTMLButtonElement;

        const CLOUD_NAME = 'dw26ujhoo';
        const UPLOAD_PRESET = 'portafolio_unsigned';

        function renumerar() {
          const filas = lista.querySelectorAll('[data-trabajo]');
          filas.forEach((fila, i) => {
            (fila.querySelector('[data-label]') as HTMLElement).textContent = `Trabajo ${i + 1}`;
            (fila.querySelector('[data-nombre]') as HTMLInputElement).name = `nombre_${i}`;
            (fila.querySelector('[data-titulo]') as HTMLInputElement).name = `titulo_${i}`;
            (fila.querySelector('[data-imagenes-json]') as HTMLInputElement).name = `imagenes_${i}`;
          });
          totalInput.value = String(filas.length);
        }

        // Crea una miniatura con su botón Quitar
        function itemImagen(url: string): HTMLElement {
          const div = document.createElement('div');
          div.dataset.img = '';
          div.className = 'flex items-center gap-3';
          div.innerHTML = `
            <img src="${url}" class="w-16 h-16 object-cover rounded-lg border border-gray-200" />
            <button type="button" data-borrar-img class="text-red-600 text-xs hover:underline">Quitar</button>
          `;
          return div;
        }

        // Lee las imágenes de una fila y guarda la lista (JSON) en su campo oculto
        function sincronizarImagenes(fila: HTMLElement) {
          const imgs = Array.from(fila.querySelectorAll<HTMLImageElement>('[data-img] img'));
          const urls = imgs.map((img) => img.src);
          const hidden = fila.querySelector('[data-imagenes-json]') as HTMLInputElement;
          hidden.value = JSON.stringify(urls);
        }

        function agregarTrabajo() {
          const fila = document.createElement('div');
          fila.dataset.trabajo = '';
          fila.className = 'border border-gray-200 rounded-xl p-4 space-y-3';
          fila.innerHTML = `
            <div class="flex justify-between items-center">
              <p data-label class="text-xs font-semibold text-gray-400 uppercase">Trabajo</p>
              <button type="button" data-borrar class="text-red-600 text-sm hover:underline">🗑️ Borrar trabajo</button>
            </div>
            <input type="text" data-nombre placeholder="Nombre"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" />
            <input type="text" data-titulo placeholder="Título"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" />
            <p class="text-xs font-medium text-gray-500">Imágenes</p>
            <div data-imagenes class="space-y-2 max-h-64 overflow-y-auto pr-1"></div>
            <input type="file" accept="image/*" multiple data-file
              class="w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-indigo-600 file:text-white file:cursor-pointer hover:file:bg-indigo-700" />
            <p data-upload-status class="text-xs text-gray-500 min-h-4"></p>
            <input type="hidden" data-imagenes-json value="[]" />
          `;
          lista.appendChild(fila);
          renumerar();
        }

        // Sube un archivo a Cloudinary y devuelve la URL
        async function subirACloudinary(file: File): Promise<string> {
          const datos = new FormData();
          datos.append('file', file);
          datos.append('upload_preset', UPLOAD_PRESET);
          const resp = await fetch(`https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`, {
            method: 'POST',
            body: datos,
          });
          if (!resp.ok) throw new Error('Falló la subida');
          const json = await resp.json() as { secure_url: string };
          return json.secure_url;
        }

        btnAgregar.addEventListener('click', agregarTrabajo);

        // Clics: borrar trabajo o quitar imagen (delegación)
        lista.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;

          const btnTrabajo = target.closest('[data-borrar]');
          if (btnTrabajo) {
            (btnTrabajo.closest('[data-trabajo]') as HTMLElement).remove();
            renumerar();
            return;
          }

          const btnImg = target.closest('[data-borrar-img]');
          if (btnImg) {
            const fila = btnImg.closest('[data-trabajo]') as HTMLElement;
            (btnImg.closest('[data-img]') as HTMLElement).remove();
            sincronizarImagenes(fila);
          }
        });

        // Subir imágenes al elegir archivo(s) (delegación)
        lista.addEventListener('change', async (e) => {
          const input = e.target as HTMLInputElement;
          if (!input.matches('[data-file]')) return;
          const files = input.files;
          if (!files || files.length === 0) return;

          const fila = input.closest('[data-trabajo]') as HTMLElement;
          const estado = fila.querySelector('[data-upload-status]') as HTMLElement;
          const contenedor = fila.querySelector('[data-imagenes]') as HTMLElement;

          const archivos = Array.from(files);
          let subidas = 0;
          for (const file of archivos) {
            estado.textContent = `⏳ Subiendo ${subidas + 1} de ${archivos.length}…`;
            try {
              const url = await subirACloudinary(file);
              contenedor.appendChild(itemImagen(url));
              sincronizarImagenes(fila);
              subidas++;
            } catch {
              // si una falla, sigue con las demás
            }
          }
          estado.textContent = subidas === archivos.length
            ? `✅ ${subidas} imagen(es) agregada(s)`
            : `⚠️ Subidas ${subidas} de ${archivos.length} (algunas fallaron)`;
          input.value = '';
        });

        renumerar();
      }
    </script>
  </body>
</html>